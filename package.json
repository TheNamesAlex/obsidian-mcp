{
  "name": "@thenamesalex/obsidian-mcp",
  "version": "0.1.2",
  "description": "MCP server for Obsidian Local REST API with LLM-wiki-oriented note organization tools",
  "type": "module",
  "bin": {
    "obsidian-mcp": "./dist/index.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "dev": "node --watch --loader ts-node/esm src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
